/bin/
*.test
coverage.out
.env
.build/
.DS_Store

# ADR-0069 stable extension tier: build/composition/ is the ONE ignored
# root for installation-dependent generated output (digest-gated by its
# composition.json, never committed — anchored to the composition root so
# an unrelated future /build asset is never silently hidden), and
# extensions/ is the installation-owned enabled set. The vanilla tree
# ships the placeholder, the approval lock, and the FIRST-PARTY units
# enabled by default (extensions/de, the German jurisdiction pack —
# presence under extensions/ IS the enablement).
/build/composition/
/extensions/*
!/extensions/.gitkeep
!/extensions/approvals.lock
!/extensions/de

# Compiled cmd binaries left in the module dir by `go build ./cmd/<role>`
# (anchored so they never match the cmd/<role> source directories; the api
# binary can't land here — backend/api/ is the OpenAPI contract directory).
/backend/worker
/backend/migrate
/backend/mcp

# Session working notes — local only, not part of the published repo
/review_*.md

# Superpowers skill artifacts (design/plan/spec docs) — local working notes,
# kept on disk to guide the work but never committed to the repo.
/docs/superpowers/

# Local secrets — never commit
.env.local

# Per-engineer AI model routing — each engineer copies config/ai-routing.example.yaml
# here (via `make install` / `make dev`) and binds their own local models. Anchored
# so the committed .example template is never matched.
/config/ai-routing.yaml

# Per-engineer dev deployment config — `make dev` seeds config/margince.yaml
# from config/margince.example.yaml on first run and then leaves it (edit it to
# change org/admin or AI posture). The admin password file it references is
# seeded alongside. Anchored so the committed .example template is never matched.
/config/margince.yaml
/config/margince-admin-password

# Storybook static build + fe-uat capture artifacts
frontend/storybook-static/
.tmp/

# Factory boundary backstop: a dispatched worker that mistakenly writes
# factory artifacts (plans/reports/UAT guides) into the worktree can never
# stage them (target-minimum-setup §1).
workspace/

# Playwright MCP scratch: page snapshots, console logs and screenshots a
# browser-driving session writes as it works. Debris from testing, never
# product — and it lands here by default, so it is ignored by name.
.playwright-mcp/

# Agent debris that has slipped into the repo before — never product:
#   - the pnpm content-addressable store (machine-local build cache)
#   - a repo-root scratch dir (real scratch belongs in the session temp dir)
#   - screenshots dropped at the repo root. Root-ANCHORED so tracked product
#     assets like frontend/src/assets/*.png are unaffected.
/.pnpm-store/
/scratchpad/
/*.png
/*.jpg
/*.jpeg
/*.gif
