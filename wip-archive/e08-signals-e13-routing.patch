+    # ---- Signals (E08 warm room, data-model §12.5) ----
+    Signal:
+      type: object
+      description: |
+        A surfaced "something changed / worth attention" item. Mirrors the `signal` table:
+        company-level and consent-gated by construction — the only mandatory attribution is
+        organizational (`resolved_org_id` after resolution); `resolved_person_id` is optional
+        and set only under a recorded consent grant (P12). Unattributable signals are
+        `dropped`, never retained as a person-level dossier.
+      required: [id, workspace_id, kind, source_channel, resolution_state, severity, summary, evidence, status, detected_at, source, captured_by, created_at, updated_at]
+      properties:
+        id: { type: string, format: uuid }
+        workspace_id: { type: string, format: uuid }
+        kind: { type: string, enum: [stalled_deal, champion_left, reengagement, buying_intent, risk, other] }
+        source_channel:
+          type: string
+          enum: [derived, inbound, web, social, deal_room_engagement]
+          default: derived
+          description: Where the raw signal came from.
+        raw_ref: { type: [string, 'null'], description: 'Pointer to the raw source payload the resolver works from: an email address/handle, a domain, a URL, or a company mention.' }
+        entity_type:
+          type: [string, 'null']
+          enum: [deal, organization, person, null]
+          description: The subject record the signal is about; null until a raw signal resolves (both entity fields set together).
+        entity_id: { type: [string, 'null'], format: uuid }
+        resolution_state:
+          type: string
+          enum: [resolved, low_confidence, unresolved, dropped]
+          description: 'The raw→entity match outcome: an ambiguous match is `low_confidence` (surfaced, never silently asserted); an unattributable one is `dropped`.'
+        resolution_confidence: { type: [number, 'null'], minimum: 0, maximum: 1 }
+        resolved_org_id: { type: [string, 'null'], format: uuid, description: The organization the raw signal resolved to (the only required attribution level). }
+        resolved_person_id: { type: [string, 'null'], format: uuid, description: Optional person resolution — set only under a recorded consent grant, never inferred. }
+        severity: { type: string, enum: [info, warn, urgent], default: info }
+        summary: { type: string }
+        evidence:
+          type: array
+          items: { $ref: '#/components/schemas/SignalEvidence' }
+          description: Per-claim evidence (evidence-or-omit, features/07 §11 gate 1).
+        status: { type: string, enum: [open, acknowledged, resolved, dismissed], default: open }
+        detected_at: { type: string, format: date-time }
+        source: { type: string }
+        captured_by: { type: string, readOnly: true, description: 'Server-stamped from the authenticated principal; never client-supplied.' }
+        version: { $ref: '#/components/schemas/RowVersion' }
+        created_at: { type: string, format: date-time }
+        updated_at: { type: string, format: date-time }
+        archived_at: { type: [string, 'null'], format: date-time }
+
+    SignalEvidence:
+      type: object
+      required: [snippet]
+      properties:
+        snippet: { type: string }
+        source_type: { type: [string, 'null'], enum: [activity, deal, signal, relationship, page, null] }
+        source_id: { type: [string, 'null'] }
+
+    CreateSignalRequest:
+      type: object
+      required: [kind, summary, source]
+      properties:
+        kind: { type: string, enum: [stalled_deal, champion_left, reengagement, buying_intent, risk, other] }
+        source_channel: { type: string, enum: [derived, inbound, web, social, deal_room_engagement], default: derived }
+        raw_ref: { type: [string, 'null'] }
+        entity_type:
+          type: [string, 'null']
+          enum: [deal, organization, person, null]
+          description: 'Subject record, both entity fields together or neither: with a subject the signal enters `resolved`; without one it enters `unresolved` (a raw item needing a raw_ref for POST /signals/{id}/resolve).'
+        entity_id: { type: [string, 'null'], format: uuid }
+        severity: { type: string, enum: [info, warn, urgent], default: info }
+        summary: { type: string }
+        evidence:
+          type: array
+          items: { $ref: '#/components/schemas/SignalEvidence' }
+        detected_at: { type: [string, 'null'], format: date-time, description: When the underlying observation happened (defaults to now). }
+        source: { type: string }
+
+    UpdateSignalRequest:
+      type: object
+      description: |
+        Triage. A `status` move to acknowledged/resolved/dismissed appends the human-outcome
+        `signal_resolution` row; `note` travels with that outcome. `resolution_state` and the
+        resolved ids are resolver-owned and not writable here.
+      properties:
+        status: { type: string, enum: [open, acknowledged, resolved, dismissed] }
+        note: { type: [string, 'null'], description: Optional outcome note recorded with a status change. }
+        severity: { type: string, enum: [info, warn, urgent] }
+
+    SignalListResponse:
+      type: object
+      required: [data, page]
+      properties:
+        data: { type: array, items: { $ref: '#/components/schemas/Signal' } }
+        page: { $ref: '#/components/schemas/PageInfo' }
+
+    SignalWarmContact:
+      type: object
+      description: One contact edge in our own graph that makes the signal warm — evidence, with its explainable §4 strength.
+      required: [person_id, relationship_kind, strength, strength_bucket]
+      properties:
+        person_id: { type: string, format: uuid }
+        full_name: { type: [string, 'null'] }
+        relationship_kind: { type: string, enum: [employment, deal_stakeholder] }
+        relationship_role: { type: [string, 'null'], description: 'e.g. cto, champion, economic_buyer.' }
+        strength: { type: integer, description: The deterministic §4 relationship strength (0–100). }
+        strength_bucket: { type: string, enum: [none, weak, moderate, strong] }
+
+    SignalWarmth:
+      type: object
+      description: |
+        The warm/cold branch with its full evidence: source signal id, resolved org id, and
+        the specific contact id(s) that make it warm. No mystery score — a numeric-only
+        answer would be a contract violation (features/07 §9).
+      required: [warm, routing, source_signal_id, resolved_org_id, contact_ids, contacts]
+      properties:
+        warm: { type: boolean }
+        routing:
+          type: string
+          enum: [warm_room, cold_queue]
+          description: The real routing branch — warm signals surface in the warm room, cold ones queue separately.
+        source_signal_id: { type: string, format: uuid }
+        resolved_org_id: { type: string, format: uuid }
+        contact_ids:
+          type: array
+          items: { type: string, format: uuid }
+          description: Empty exactly when cold.
+        contacts:
+          type: array
+          items: { $ref: '#/components/schemas/SignalWarmContact' }
+
+    SignalIntroPath:
+      type: object
+      description: |
+        An actionable warm-intro path — names the route-in contact, the relationship we
+        have, and a concrete next move with a drafted message. Proposal only: the send is
+        the 🟡 confirm-first send tool, never this read.
+      required: [signal_id, resolved_org_id, contact_id, relationship, next_move, evidence]
+      properties:
+        signal_id: { type: string, format: uuid }
+        resolved_org_id: { type: string, format: uuid }
+        contact_id: { type: string, format: uuid, description: The route-in contact (the strongest live relationship at the resolved organization). }
+        contact_name: { type: [string, 'null'] }
+        relationship: { $ref: '#/components/schemas/SignalWarmContact' }
+        next_move:
+          type: object
+          required: [kind, draft_subject, draft_body, ai_disclosure]
+          properties:
+            kind:
+              type: string
+              enum: [draft_to_contact, intro_request]
+              description: 'intro_request when the signal resolved (under consent) to a specific person other than the route-in contact; otherwise a direct draft to the contact.'
+            draft_subject: { type: string }
+            draft_body: { type: string, description: Renders the Art. 50 AI-assisted disclosure (features/07 §11 gate 9). }
+            ai_disclosure: { type: string, description: The machine-readable Art. 50 disclosure line the draft carries. }
+        evidence:
+          type: object
+          description: Provenance back to the warm signal (evidence-or-omit).
+          required: [source_signal_id, resolved_org_id, contact_ids]
+          properties:
+            source_signal_id: { type: string, format: uuid }
+            resolved_org_id: { type: string, format: uuid }
+            contact_ids: { type: array, items: { type: string, format: uuid } }
+
     # ---- List / Tag ----
     List:
       type: object
